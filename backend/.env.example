# ── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database ─────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/marketsync

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET=change_me_in_production
JWT_ACCESS_EXPIRES_IN=15m
COOKIE_SECRET=change_me_in_production

# ── Google OAuth ─────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# ── Shopify ──────────────────────────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_API_VERSION=2026-01
# read_all_orders richiede approvazione Shopify ed è necessario per accedere allo storico
# ordini oltre i 60 giorni. Rimuoverlo se non serve accedere a dati storici oltre questa soglia.
# IMPORTANTE: gli store già collegati devono ricollegare Shopify (disconnetti e riconnetti
# dalla sezione Integrazioni) per autorizzare il nuovo scope. Senza riconnessione l'accesso
# agli ordini oltre i 60 giorni fallirà silenziosamente con dati parziali o un errore 403.
SHOPIFY_SCOPES=read_orders,read_products,read_analytics,read_all_orders
SHOPIFY_CALLBACK_URL=http://localhost:4000/api/v1/integrations/shopify/callback
# URL pubblico del backend usato per registrare webhook Shopify (es. app/uninstalled).
# In produzione è obbligatorio: il backend non si avvia senza questo valore.
# Locale: http://localhost:4000  |  Produzione Render: https://tuo-backend.onrender.com
BACKEND_PUBLIC_URL=http://localhost:4000

# ── Meta Ads ─────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:4000/api/v1/integrations/meta-ads/callback
META_SCOPES=ads_read

# ── Google Ads ───────────────────────────────────────────
GOOGLE_ADS_API_VERSION=v24
# GOOGLE_ADS_DEVELOPER_TOKEN appartiene all'app (lato backend) — gli utenti finali
# NON inseriscono il developer token. È un token unico dell'applicazione MarketSync,
# richiesto a Google tramite il form "Apply for access" nel Google Ads API Center.
# Livelli di accesso:
#   - Test Access: funziona solo con account Google Ads di tipo "test" (nessuna spesa reale).
#   - Basic Access: necessario per account Google Ads reali (approvazione Google richiesta).
#   - Standard Access: per volumi elevati (approvazione aggiuntiva richiesta).
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
# GOOGLE_ADS_REDIRECT_URI deve corrispondere ESATTAMENTE alla redirect URI registrata
# in Google Cloud Console → API e servizi → Credenziali → ID client OAuth 2.0.
# Anche una differenza minima (trailing slash, http vs https) causa errore redirect_uri_mismatch.
GOOGLE_ADS_REDIRECT_URI=http://localhost:4000/api/v1/integrations/google-ads/callback
GOOGLE_ADS_SCOPES=https://www.googleapis.com/auth/adwords

# ── SendGrid ─────────────────────────────────────────────
SENDGRID_API_KEY=
# Il mittente DEVE essere verificato in SendGrid (Sender Authentication).
# Gmail come mittente richiede Domain Authentication su SendGrid — non usare gmail direttamente.
# Imposta con l'indirizzo verificato (es. noreply@tuodominio.it) una volta completata la verifica.
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=MarketSync
# URL pubblico del logo ufficiale MarketSync da mostrare nell'header delle email transazionali.
# Se vuoto, l'header mostrerà il testo "MarketSync" come fallback.
# Impostare con l'URL definitivo una volta che il logo è online.
EMAIL_LOGO_URL=
# Indirizzo email di supporto opzionale mostrato nelle email transazionali (footer/link mailto).
# Se vuoto, il footer indica comunque che si può rispondere direttamente alla email.
EMAIL_SUPPORT_EMAIL=aw.thirdmind@gmail.com

# ── CORS ─────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Frontend ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Encryption ────────────────────────────────────────────
# 32-byte symmetric key for AES-256-GCM, encoded as 64 hex characters.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ── Cloudinary (upload foto profilo) ──────────────────────
# Lascia vuoto per disabilitare l'upload avatar. Se configurato,
# tutti e tre i valori sono obbligatori per il funzionamento.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_PROFILE_AVATAR_FOLDER=marketsync/profile-avatars
